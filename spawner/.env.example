# Flashpoint spawner configuration. Copy to /opt/flashpoint/.env and fill in.
# This file must NOT be committed with real values.

# Port the spawner API listens on.
FP_SPAWNER_PORT=2880

# Docker image used for spawned agents (built from agent/Dockerfile).
FP_AGENT_IMAGE=flashpoint/agent:latest

# Host address advertised in per-agent gateway URLs. Set to the spawner host's
# reachable IP (or a routed VIP in multi-host setups).
FP_GATEWAY_HOST=192.168.1.10

# Decision-log database. Agents persist decisions here so they survive teardown.
# Leave host empty to disable decision logging.
FP_DECISIONS_HOST=
FP_DECISIONS_PASS=

# Optional orchestrator gateway URL passed to agents.
FP_ORCHESTRATOR=

# Optional JSONL spawn registry path — one line per spawn/destroy, kept after
# teardown so an agent_id can always be traced to its exact spawn.
FP_REGISTRY_PATH=/var/lib/flashpoint/registry.jsonl

# Optional Postgres DSN for a FLEET-WIDE registry (any spawner can resolve any
# agent_id). When set, this takes precedence over FP_REGISTRY_PATH and the
# spawner auto-creates the spawn_registry table on startup. Requires psycopg2.
# FP_REGISTRY_DSN=host=db.example.com dbname=flashpoint user=flashpoint password=...
FP_REGISTRY_DSN=

# Default model when a spawn does not override it.
FP_DEFAULT_MODEL=openrouter/anthropic/claude-opus-4-8
